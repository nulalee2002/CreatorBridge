# CreatorBridge frontend environment variables
# Copy names only. Never commit real secrets.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Optional frontend integrations
VITE_TURNSTILE_SITE_KEY=
VITE_GOOGLE_CLIENT_ID=

# Do not add secret API keys with VITE_ prefixes.
# Anthropic, Stripe secret, Stripe webhook, and Supabase service role keys belong in backend/Supabase secrets only.
