# CreatorBridge frontend environment variables
# Copy names only. Never commit real secrets.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Optional frontend integrations
VITE_TURNSTILE_SITE_KEY=
VITE_GOOGLE_CLIENT_ID=

# QA test account credentials (used by scripts/verify-*.mjs only — never expose in frontend)
# Set these in your local .env file. Never commit the actual values.
QA_CREATOR_EMAIL=drl33+creator@creatorbridge.studio
QA_CREATOR_PASS=
QA_CLIENT_EMAIL=drl33+client@creatorbridge.studio
QA_CLIENT_PASS=
QA_ADMIN_EMAIL=drl33@creatorbridge.studio
QA_ADMIN_PASS=

# Backend-only keys (set in Vercel environment variables and Supabase edge function secrets)
# SUPABASE_SERVICE_ROLE_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# Do not add secret API keys with VITE_ prefixes.
# Anthropic/OpenAI, Twilio, Stripe secret, Stripe webhook, and Supabase service role keys belong in backend/Supabase secrets only.
