{
  "name": "creatorbridge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "audit:platform": "node scripts/audit-platform.mjs",
    "audit:env": "node scripts/audit-env.mjs",
    "verify:notifications": "node --env-file=.env scripts/verify-notification-center.mjs",
    "verify:email-provider": "node --env-file=.env scripts/verify-email-provider.mjs",
    "verify:release-payment-security": "node --env-file=.env scripts/verify-release-payment-security.mjs",
    "verify:admin-support-search": "node --env-file=.env scripts/verify-admin-support-search.mjs",
    "verify:launch-sweep": "node --env-file=.env scripts/verify-launch-sweep.mjs",
    "verify:external-env": "node --env-file=.env scripts/verify-external-env.mjs",
    "qa:create-accounts": "node scripts/create-qa-accounts.mjs",
    "qa": "npm run build && npm run audit:platform && npm run audit:env",
    "generate:sitemap": "node scripts/generate-sitemap.js"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.1.0",
    "@supabase/supabase-js": "^2.101.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.30.3",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "vite": "^8.0.16"
  },
  "overrides": {
    "ws": "^8.21.0"
  }
}
